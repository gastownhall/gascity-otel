{
  "uid": "gc-beads-health",
  "title": "Beads Store Health",
  "description": "bd storage operations, errors, lock contention, and issue tracking",
  "tags": ["gascity"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Storage Ops (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(increase(bd_storage_operations_total[1h]))",
          "legendFormat": "ops"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Storage Errors (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(increase(bd_storage_errors_total[1h]))",
          "legendFormat": "errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "DB Retries (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(increase(bd_db_retry_count_total[1h]))",
          "legendFormat": "retries"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Open Issues",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(bd_issue_count)",
          "legendFormat": "issues"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Storage Op Rate by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (type) (rate(bd_storage_operations_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 11,
      "title": "Storage Error Rate by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (type) (rate(bd_storage_errors_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops",
          "color": { "mode": "palette-classic-by-name" }
        }
      }
    },
    {
      "id": 20,
      "title": "Storage Op Latency (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(bd_storage_operation_duration_ms_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(bd_storage_operation_duration_ms_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 21,
      "title": "DB Lock Wait (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(bd_db_lock_wait_ms_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(bd_db_lock_wait_ms_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 22,
      "title": "Issues by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "bd_issue_count",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 30,
      "title": "Circuit Breaker Trips",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(rate(bd_db_circuit_trips_total[5m]))",
          "legendFormat": "trips/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 31,
      "title": "Circuit Breaker Rejections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(rate(bd_db_circuit_rejected_total[5m]))",
          "legendFormat": "rejected/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
