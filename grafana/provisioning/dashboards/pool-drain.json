{
  "uid": "gc-pool-drain",
  "title": "Pool & Drain Operations",
  "description": "Pool scaling, scale_check latency, drain lifecycle, and mail operations",
  "tags": ["gascity"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Pool Spawns (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(increase(gc_pool_spawns_total[1h]))",
          "legendFormat": "spawns"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Pool Removes (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(increase(gc_pool_removes_total[1h]))",
          "legendFormat": "removes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Drain Transitions (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(increase(gc_drain_transitions_total[1h]))",
          "legendFormat": "transitions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Mail Ops (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(increase(gc_mail_operations_total[1h]))",
          "legendFormat": "ops"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Pool Spawns by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (agent) (rate(gc_pool_spawns_total[5m]))",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 11,
      "title": "Pool Removes by Reason",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (agent, reason) (rate(gc_pool_removes_total[5m]))",
          "legendFormat": "{{agent}} — {{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 20,
      "title": "Pool Check Latency (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(gc_pool_check_duration_ms_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gc_pool_check_duration_ms_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 21,
      "title": "Pool Check Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (agent) (rate(gc_pool_check_duration_ms_count{status=\"error\"}[5m]))",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 30,
      "title": "Drain Transitions by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (transition) (rate(gc_drain_transitions_total[5m]))",
          "legendFormat": "{{transition}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 31,
      "title": "Drains by Reason",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (reason) (rate(gc_drain_transitions_total[5m]))",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 40,
      "title": "Mail Ops by Operation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (operation) (rate(gc_mail_operations_total[5m]))",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 41,
      "title": "Mail Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (operation) (rate(gc_mail_operations_total{status=\"error\"}[5m]))",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
