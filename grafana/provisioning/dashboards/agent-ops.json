{
  "uid": "gc-agent-ops",
  "title": "Agent Operations",
  "description": "Agent lifecycle, bd call performance, and session activity",
  "tags": ["gascity"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Bead Store Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "gc_bead_store_healthy",
          "legendFormat": "{{city}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Unhealthy", "color": "red" }, "1": { "text": "Healthy", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Agent Starts (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(increase(gc_agent_starts_total[1h]))",
          "legendFormat": "starts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Agent Crashes (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(increase(gc_agent_crashes_total[1h]))",
          "legendFormat": "crashes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Quarantines (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(increase(gc_agent_quarantines_total[1h]))",
          "legendFormat": "quarantines"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Agent Starts by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (agent) (rate(gc_agent_starts_total[5m]))",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 11,
      "title": "Agent Stops by Reason",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (agent, reason) (rate(gc_agent_stops_total[5m]))",
          "legendFormat": "{{agent}} — {{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 12,
      "title": "Idle Kills by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (agent) (rate(gc_agent_idle_kills_total[5m]))",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 20,
      "title": "bd Call Rate by Subcommand",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (subcommand) (rate(gc_bd_calls_total[5m]))",
          "legendFormat": "{{subcommand}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 21,
      "title": "bd Error Rate by Subcommand",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (subcommand) (rate(gc_bd_calls_total{status=\"error\"}[5m]))",
          "legendFormat": "{{subcommand}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops",
          "color": { "mode": "palette-classic-by-name" }
        }
      }
    },
    {
      "id": 22,
      "title": "bd Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(gc_bd_duration_ms_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gc_bd_duration_ms_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(gc_bd_duration_ms_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 30,
      "title": "Session Nudge Rate by Target",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (target) (rate(gc_session_nudges_total[5m]))",
          "legendFormat": "{{target}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 31,
      "title": "Sling Dispatches",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (target_type, method) (rate(gc_sling_dispatches_total[5m]))",
          "legendFormat": "{{target_type}} / {{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 32,
      "title": "Reconcile Cycles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(rate(gc_reconcile_cycles_total[5m]))",
          "legendFormat": "cycles/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 40,
      "title": "Config Reloads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (status) (rate(gc_config_reloads_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "id": 41,
      "title": "Controller Lifecycle Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (event) (rate(gc_controller_lifecycle_total[5m]))",
          "legendFormat": "{{event}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
